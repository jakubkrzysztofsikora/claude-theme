{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude.themes/schema/v1/theme.json",
  "title": "Claude White-Label Theme Schema v1",
  "description": "JSON Schema for validating Claude white-label theme files. All themes must conform to this schema to be processed by the build system.",
  "type": "object",
  "required": [
    "name",
    "id",
    "version",
    "author",
    "description",
    "license",
    "preview",
    "tokens"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable theme name",
      "minLength": 1,
      "maxLength": 64,
      "examples": ["Ocean Dark", "Rose Quartz"]
    },
    "id": {
      "type": "string",
      "description": "Unique kebab-case identifier for the theme",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64,
      "examples": ["ocean-dark", "rose-quartz"]
    },
    "version": {
      "type": "string",
      "description": "SemVer version string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-([0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*))?(?:\\+([0-9A-Za-z-]+(\\.[0-9A-Za-z-]+)*))?$",
      "examples": ["1.0.0", "2.1.0-beta.1"]
    },
    "author": {
      "type": "string",
      "description": "Theme author name or organization",
      "minLength": 1,
      "examples": ["Jane Doe", "Claude Themes Community"]
    },
    "description": {
      "type": "string",
      "description": "Short description of the theme",
      "minLength": 1,
      "maxLength": 512,
      "examples": ["A calming ocean-inspired dark theme"]
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier or custom license string",
      "minLength": 1,
      "examples": ["MIT", "Apache-2.0", "CC-BY-4.0"]
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for categorizing the theme",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      },
      "minItems": 0,
      "uniqueItems": true,
      "examples": [["dark", "professional", "blue"]]
    },
    "preview": {
      "type": "object",
      "description": "Five representative colors for theme previews and thumbnails",
      "required": ["background", "surface", "textPrimary", "brandPrimary", "userMessageText"],
      "properties": {
        "background": {
          "$ref": "#/definitions/hexColor",
          "description": "Main background color"
        },
        "surface": {
          "$ref": "#/definitions/hexColor",
          "description": "Card/surface background color"
        },
        "textPrimary": {
          "$ref": "#/definitions/hexColor",
          "description": "Primary text color"
        },
        "brandPrimary": {
          "$ref": "#/definitions/hexColor",
          "description": "Brand accent color"
        },
        "userMessageText": {
          "$ref": "#/definitions/hexColor",
          "description": "User message text color"
        }
      },
      "additionalProperties": false
    },
    "tokens": {
      "type": "object",
      "description": "Design tokens for styling Claude's interface",
      "required": ["color"],
      "properties": {
        "color": {
          "type": "object",
          "description": "Color tokens for the theme",
          "required": [
            "brandPrimary",
            "background",
            "surface",
            "textPrimary",
            "userMessageText"
          ],
          "properties": {
            "brandPrimary": {
              "$ref": "#/definitions/hexColor",
              "description": "Primary brand/accent color used for buttons, links, highlights"
            },
            "brandSecondary": {
              "$ref": "#/definitions/hexColor",
              "description": "Secondary brand color for gradients and accents"
            },
            "background": {
              "$ref": "#/definitions/hexColor",
              "description": "Main page background color"
            },
            "surface": {
              "$ref": "#/definitions/hexColor",
              "description": "Card, input, and elevated surface background color"
            },
            "surfaceHover": {
              "$ref": "#/definitions/hexColor",
              "description": "Surface color on hover state"
            },
            "textPrimary": {
              "$ref": "#/definitions/hexColor",
              "description": "Primary text color for headings and body"
            },
            "textSecondary": {
              "$ref": "#/definitions/hexColor",
              "description": "Secondary/muted text color"
            },
            "textMuted": {
              "$ref": "#/definitions/hexColor",
              "description": "Tertiary/hint text color"
            },
            "border": {
              "$ref": "#/definitions/hexColor",
              "description": "Border and divider color"
            },
            "borderFocus": {
              "$ref": "#/definitions/hexColor",
              "description": "Border color when element is focused"
            },
            "userMessageText": {
              "$ref": "#/definitions/hexColor",
              "description": "Text color inside user message bubbles"
            },
            "userMessageBackground": {
              "$ref": "#/definitions/hexColor",
              "description": "Background color of user message bubbles"
            },
            "assistantMessageText": {
              "$ref": "#/definitions/hexColor",
              "description": "Text color inside assistant message bubbles"
            },
            "assistantMessageBackground": {
              "$ref": "#/definitions/hexColor",
              "description": "Background color of assistant message bubbles"
            },
            "codeBackground": {
              "$ref": "#/definitions/hexColor",
              "description": "Inline and block code background color"
            },
            "codeText": {
              "$ref": "#/definitions/hexColor",
              "description": "Code text color"
            },
            "error": {
              "$ref": "#/definitions/hexColor",
              "description": "Error state color"
            },
            "success": {
              "$ref": "#/definitions/hexColor",
              "description": "Success state color"
            },
            "warning": {
              "$ref": "#/definitions/hexColor",
              "description": "Warning state color"
            }
          },
          "additionalProperties": {
            "$ref": "#/definitions/hexColor"
          }
        },
        "typography": {
          "type": "object",
          "description": "Optional typography customization",
          "properties": {
            "fontFamily": {
              "type": "string",
              "description": "CSS font-family value",
              "examples": ["'Inter', sans-serif", "'Fira Code', monospace"]
            },
            "fontUrl": {
              "type": "string",
              "description": "URL to a web font (Google Fonts, self-hosted, etc.)",
              "format": "uri",
              "pattern": "^https?://.+$",
              "examples": ["https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700"]
            },
            "fontSizeBase": {
              "type": "string",
              "description": "Base font size",
              "pattern": "^\\d+(\\.\\d+)?(px|rem|em)$",
              "examples": ["16px", "1rem"]
            },
            "lineHeight": {
              "type": "number",
              "description": "Line height multiplier",
              "minimum": 1,
              "maximum": 3,
              "examples": [1.5, 1.75]
            }
          },
          "additionalProperties": false
        },
        "logo": {
          "type": "object",
          "description": "Optional custom logo replacement",
          "properties": {
            "type": {
              "type": "string",
              "description": "Logo format type",
              "enum": ["svg", "text", "emoji"]
            },
            "content": {
              "type": "string",
              "description": "SVG markup, text string, or emoji character(s)",
              "minLength": 1
            },
            "viewBox": {
              "type": "string",
              "description": "SVG viewBox attribute (required when type=svg)",
              "pattern": "^\\d+( \\d+){3}$",
              "examples": ["0 0 32 32"]
            }
          },
          "required": ["type", "content"],
          "additionalProperties": false
        },
        "favicon": {
          "type": "string",
          "description": "Optional favicon URL or data URI",
          "format": "uri",
          "examples": ["data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg'..."]
        }
      },
      "additionalProperties": false
    },
    "terminal": {
      "type": "object",
      "description": "Optional Claude Code CLI theme overrides. NOTE: this schema is documentation; build-theme.js validateTheme() is the runtime gate.",
      "properties": {
        "userColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Color for user message labels in terminal"
        },
        "assistantColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Color for assistant message labels + body text in terminal"
        },
        "backgroundColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Message background color"
        },
        "promptColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Input prompt / prompt border color"
        },
        "errorColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Error message color"
        },
        "successColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Success message color"
        },
        "systemColor": {
          "$ref": "#/definitions/colorValue",
          "description": "Accent color for plan mode / IDE indicators"
        },
        "base": {
          "type": "string",
          "enum": [
            "dark",
            "light",
            "dark-daltonized",
            "light-daltonized",
            "dark-ansi",
            "light-ansi"
          ],
          "description": "Claude Code base preset this theme extends. If omitted, inferred from tags."
        },
        "deriveAll": {
          "type": "boolean",
          "description": "When true, derive the full token set (diffs, rainbow, subagents, etc.) from the palette. Default false (only explicitly-mapped tokens are emitted). Requires hex tokens.color.success/error/warning."
        },
        "overrides": {
          "type": "object",
          "description": "Raw escape hatch: a map of Claude Code token name -> color value. Token names are validated against the verified set in code; values accept any colorValue form.",
          "additionalProperties": { "$ref": "#/definitions/colorValue" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "hexColor": {
      "type": "string",
      "description": "6-digit hexadecimal color with leading hash",
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "examples": ["#FF5733", "#1a1a2e"]
    },
    "colorValue": {
      "type": "string",
      "description": "A color value: hex (#rgb or #rrggbb), rgb(r,g,b) with 0-255 channels, ansi256(n) with 0-255, or ansi:<name>. Used only for terminal.* fields (tokens.color stays hex-only).",
      "pattern": "^(#(?:[0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})|rgb\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*\\)|ansi256\\(\\d{1,3}\\)|ansi:[a-zA-Z]+)$",
      "examples": ["#FF007F", "#f0a", "rgb(255,0,127)", "ansi256(213)", "ansi:magentaBright"]
    }
  }
}
