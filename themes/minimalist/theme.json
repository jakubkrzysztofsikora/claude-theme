      "brandAccent": "#333333",
      "background": "#FFFFFF",
      "surface": "#F5F5F5",
      "surfaceHover": "#EBEBEB",
      "textPrimary": "#1A1A1A",
      "textSecondary": "#737373",
      "textMuted": "#A3A3A3",
      "border": "#E5E5E5",
      "success": "#4D4D4D",
      "warning": "#737373",
