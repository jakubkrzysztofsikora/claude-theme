{
  "$schema": "./schema.json",
  "name": "A11y First",
  "id": "a11y-first",
  "version": "1.0.0",
  "author": "Claude Themes Community",
  "description": "WCAG 2.1 AAA compliant high-contrast theme with pure black background, pure white text, vivid colorblind-safe accents, and Atkinson Hyperlegible font for maximum accessibility.",
  "license": "MIT",
  "tags": [
    "high-contrast",
    "accessibility",
    "a11y",
    "wcag-aaa"
  ],
  "preview": {
    "primary": "#00CCFF",
    "secondary": "#FFD600",
    "background": "#000000",
    "surface": "#141414",
    "text": "#FFFFFF"
  },
  "tokens": {
    "color": {
      "brandPrimary": "#00CCFF",
      "brandAccent": "#FFD600",
      "background": "#000000",
      "surface": "#141414",
      "surfaceHover": "#2A2A2A",
      "textPrimary": "#FFFFFF",
      "textSecondary": "#B8B8B8",
      "textMuted": "#B5B5B5",
      "border": "#FFFFFF",
      "success": "#00FF66",
      "warning": "#FFAA00",
      "error": "#FF8080",
      "userMessageText": "#00FFCC"
    },
    "typography": {
      "fontFamily": "Atkinson Hyperlegible",
