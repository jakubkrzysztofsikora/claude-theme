{
  "name": "claude-whitelabel-themes",
  "version": "1.0.0",
  "description": "Author a Claude theme once, apply it across the claude.ai web UI, the Claude Code CLI, and Warp — from one theme JSON. Zero runtime dependencies, MIT. Unofficial, not affiliated with Anthropic.",
  "scripts": {
    "theme:apply": "node .claude/skills/whitelabel-theme/build-theme.js apply",
    "theme:compile": "node .claude/skills/whitelabel-theme/build-theme.js compile",
    "theme:list": "node .claude/skills/whitelabel-theme/build-theme.js list",
    "theme:validate": "node .claude/skills/whitelabel-theme/build-theme.js validate",
    "theme:preview": "node .claude/skills/whitelabel-theme/build-theme.js preview",
    "theme:init": "node .claude/skills/whitelabel-theme/build-theme.js init",
    "test": "node --test .claude/skills/whitelabel-theme/__tests__/*.test.js",
    "marketplace:build": "node scripts/build-marketplace.js && cd marketplace && npm run build",
    "validate:themes": "node scripts/validate-theme.js themes/*/theme.json"
  },
  "keywords": ["claude", "theme", "whitelabel", "customization", "zero-dependency"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/claude-whitelabel-themes.git"
  }
}
